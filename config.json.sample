{
    "globalShortcut": "Ctrl+Space",
    "mcpServers": { 
	"superpowers-mcp-server": {
	    "command": "superpowers-mcp-server",
	    "args": [],
	    "env": {
		"SUPERPOWERD_SESSION_TOKEN": "${SUPERPOWERD_SESSION_TOKEN}"
	    }
	}
    },
    "hooks": {
	"agentSpawn": "anvillm-hook agentSpawn",
	"userPromptSubmit": "anvillm-hook userPromptSubmit",
	"stop": "anvillm-hook stop"
    }
}
